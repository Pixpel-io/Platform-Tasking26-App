# Supabase — create a project at https://supabase.com and copy these from
# Project Settings → API. Then duplicate this file to `.env.local`.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only key (NEVER exposed to the browser). Used by the thin Node layer
# for invite/notification emails and, later, Stripe + AI. Leave blank for now.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL — used to build auth redirect/callback links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AWS S3 — server-only (no NEXT_PUBLIC_ prefix; these must NEVER reach the
# browser). When all four are set, chat attachments upload straight to S3 via
# server-issued presigned POSTs; leave blank to keep using Supabase Storage.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# Optional per-file cap for S3 uploads, in MB (default 300).
S3_MAX_UPLOAD_MB=

# Resend — server-only. Used to send invite emails. Get a key at
# https://resend.com (free tier). Leave RESEND_API_KEY blank to disable email
# sending; invite rows + accept links are still created either way.
RESEND_API_KEY=
# The "from" address. Use a sender on a domain you've verified in Resend, or
# Resend's sandbox sender (onboarding@resend.dev) which only delivers to your
# own account email.
INVITE_FROM_EMAIL=Tasking <support@your-verified-domain.com>
# Optional reply-to address shown to recipients.
INVITE_REPLY_TO=support@your-verified-domain.com
